---
import { getAllPhotoPosts } from "../lib/sanity";
import { getMasonryGrid } from "../lib/grid";
import Photo from "@components/Photo.astro";
import Layout from "../layouts/main.astro";

const photos = await getAllPhotoPosts();
const layout = getMasonryGrid(photos, 6, false);
---
  <Layout title="Snaps - by Tushar">
      <section class="masonry-grid" aria-label="Photo Gallery" id="masonry-grid">
        {
          layout.map((photo, index) => (
            <Photo
              title={photo.title}
              url={photo.image}
              slug={photo.slug}
              downloadUrl={photo.downloadUrl}
              orientation={photo.orientation}
              className={photo.className}
              loading={index > 10 ? "lazy" : "eager"}
              allClasses={photo.gridSize}
            />
          ))
        }
      </section>
      <script>

const GRID_SIZE = {
    square:"grid-square",
    portrait: "grid-portrait",
    landscape: "grid-landscape",
    bigSquare: "grid-big-square",
  };
      function arrangeTiles() {

        document.querySelectorAll(".masonry-grid-picture").forEach(picture => {
          const sizes = picture.dataset.gridSizes.split(",");
          const size = sizes[Math.floor(sizes.length * Math.random())];
          const className = GRID_SIZE[size];
          picture.classList.add(className);
        });
      }
      

    function shuffleElements() {
    const container = document.getElementById("masonry-grid");
    const elements = Array.from(container.children); // Get all children

    for (let i = elements.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        // Swap elements in the array
        [elements[i], elements[j]] = [elements[j], elements[i]];
    }

    // Re-append to the container; appendChild moves nodes instead of copying them
    elements.forEach(el => container.appendChild(el));
}

        arrangeTiles();
        shuffleElements();
      </script>

    </Layout>
