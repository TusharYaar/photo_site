---
import "../../styles/global.css";
import { getAllPhotoPosts, getPhotoPostBySlug, urlForImage } from "../../lib/sanity";

export async function getStaticPaths() {
  const posts = await getAllPhotoPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getPhotoPostBySlug(slug) : null;

if (!post) {
  throw new Error(`Photo post not found for slug: ${slug}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{post.title} - Lenscape</title>
  </head>
  <body class="site-shell">
    <main class="container detail-page">
      <a href="/" class="back-link">Back to gallery</a>
      <article class="detail-card">
        <div class="detail-content">
        </div>
      </article>
    </main>
  </body>
</html>
