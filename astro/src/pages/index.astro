---
import "../styles/global.css";
import { getAllPhotoPosts } from "../lib/sanity";
import { getMasonryGrid } from "../lib/grid";
import Photo from "../components/Photo.astro";

const photos = await getAllPhotoPosts();
const layout = getMasonryGrid(photos, 6, true);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Snaps - by Tushar</title>
    <meta name="description" content="" />
  </head>

  <body class="site-shell">
    <main class="container">
      <header class="hero">
        <p class="hero-kicker">Photography</p>
        <h1 class="hero-title">Lenscape Journal</h1>
        <p class="hero-subtitle">A modern, statically generated photo archive with editorial storytelling.</p>
      </header>

      <section class="masonry-grid" aria-label="Photo Gallery">
        {
          layout.map((photo, index) => (
            <Photo
              title={photo.title}
              url={photo.image}
              downloadUrl={photo.downloadUrl}
              orientation={photo.orientation}
              className={photo.className}
              loading={index > 10 ? "lazy" : "eager"}
            />
          ))
        }
      </section>
    </main>
  </body>
</html>
