---
import { Picture } from "astro:assets";


const { title, url, downloadUrl, orientation, className } = Astro.props;


const width = orientation === "potraint" ? 300 : 600;
const height = orientation === "potraint" ? 540 : 270 ;

---

<article class="masonry-grid-picture" class:list={[orientation, className]}>
    <Picture src={url} alt={title} 
    width={width}
    height={height}
    loading="lazy" />
</article>



