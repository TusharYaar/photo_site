---
import Layout from "../../layouts/main.astro";
import { getAllPhotoPosts, getPhotoPostBySlug, urlForImage } from "../../lib/sanity";

export async function getStaticPaths() {
  const posts = await getAllPhotoPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const photo = slug ? await getPhotoPostBySlug(slug) : null;

if (!photo) {
  throw new Error(`Photo post not found for slug: ${slug}`);
}
---

<Layout title={photo.title} downloadUrl={photo.downloadUrl} slug={slug}>
  <section class="image-wrapper">
    <img 
      src={photo.image} 
      alt={photo.title} 
      class="main-photo"
    />
  </section>
  </Layout>
